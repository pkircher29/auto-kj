           <item><widget class="QToolButton" name="btnYtmHelp"><property name="text"><string>?</string></property></widget></item>
           <item><widget class="QLabel" name="label_2"><property name="text"><string>API Key:</string></property></widget></item>
           <item><widget class="QLineEdit" name="lineEditYtmApiKey"><property name="placeholderText"><string>YouTube Data API v3 key (optional)</string></property></widget></item>
          </layout>
