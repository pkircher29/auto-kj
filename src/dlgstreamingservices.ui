     <!-- ═══════════════════════  ITUNES / APPLE MUSIC TAB  ═════════════ -->
     <widget class="QWidget" name="tabItunes">
      <attribute name="title"><string>iTunes / Apple Music</string></attribute>
      <layout class="QVBoxLayout" name="vlItunes">

       <item>
