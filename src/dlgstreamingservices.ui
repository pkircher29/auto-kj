<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>DlgStreamingServices</class>
 <widget class="QDialog" name="DlgStreamingServices">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>900</width><height>640</height></rect>
  </property>
  <property name="windowTitle">
   <string>Streaming Services</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="QTabWidget" name="tabWidget">
     <property name="currentIndex"><number>0</number></property>

     <!-- ═══════════════════════  SPOTIFY TAB  ══════════════════════════ -->
     <widget class="QWidget" name="tabSpotify">
      <attribute name="title"><string>Spotify</string></attribute>
      <layout class="QVBoxLayout" name="vlSpotify">

       <!-- header row -->
       <item>
        <layout class="QHBoxLayout">
         <item><widget class="QLabel" name="lblSpotifyStatus"><property name="text"><string>● Disconnected</string></property></widget></item>
         <item><spacer><property name="orientation"><enum>Qt::Horizontal</enum></property></spacer></item>
         <item>
          <layout class="QHBoxLayout">
           <item><widget class="QLabel" name="label"><property name="text"><string>Client ID:</string></property></widget></item>
           <item><widget class="QLineEdit" name="lineEditSpotifyClientId"><property name="placeholderText"><string>Spotify app Client ID</string></property></widget></item>
           <item><widget class="QToolButton" name="btnSpotifyHelp"><property name="text"><string>?</string></property></widget></item>
          </layout>
         </item>
         <item><widget class="QPushButton" name="btnSpotifyConnect"><property name="text"><string>Connect</string></property></widget></item>
        </layout>
       </item>

       <!-- playlist + track splitter -->
       <item>
        <widget class="QSplitter" name="splitterSpotify">
         <property name="orientation"><enum>Qt::Horizontal</enum></property>
         <widget class="QListWidget" name="listSpotifyPlaylists">
          <property name="minimumWidth"><number>220</number></property>
         </widget>
         <widget class="QTableWidget" name="tableSpotifyTracks">
          <property name="selectionBehavior"><enum>QAbstractItemView::SelectRows</enum></property>
          <property name="editTriggers"><set>QAbstractItemView::NoEditTriggers</set></property>
          <property name="alternatingRowColors"><bool>true</bool></property>
          <column><property name="text"><string>Artist</string></property></column>
          <column><property name="text"><string>Title</string></property></column>
          <column><property name="text"><string>Album</string></property></column>
          <column><property name="text"><string>Duration</string></property></column>
         </widget>
        </widget>
       </item>

       <!-- transport -->
       <item>
        <layout class="QHBoxLayout">
         <item><widget class="QPushButton" name="btnSpotifyPrev"><property name="text"><string>⏮</string></property><property name="maximumWidth"><number>40</number></property></widget></item>
         <item><widget class="QPushButton" name="btnSpotifyPlay"><property name="text"><string>⏯</string></property><property name="maximumWidth"><number>40</number></property></widget></item>
         <item><widget class="QPushButton" name="btnSpotifyNext"><property name="text"><string>⏭</string></property><property name="maximumWidth"><number>40</number></property></widget></item>
         <item><widget class="QLabel" name="lblSpotifyNowPlaying"><property name="text"><string>Not playing</string></property></widget></item>
        </layout>
       </item>

      </layout>
     </widget>

     <!-- ═══════════════════════  YOUTUBE MUSIC TAB  ════════════════════ -->
     <widget class="QWidget" name="tabYtm">
      <attribute name="title"><string>YouTube Music</string></attribute>
      <layout class="QVBoxLayout" name="vlYtm">

       <item>
